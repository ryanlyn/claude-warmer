{
  "name": "claude-warmer",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "claude-warmer": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --clean",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' '*.{ts,js,json}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' '*.{ts,js,json}'",
    "check": "npm run lint && npm run format:check && npm run test:coverage",
    "prepublishOnly": "npm run check && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "description": "TUI tool that keeps Claude Code session caches warm by periodically resuming sessions",
  "keywords": [
    "claude",
    "claude-code",
    "cache",
    "warmer",
    "tui",
    "ink"
  ],
  "author": "Ryan Lyn",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanlyn/claude-warmer.git"
  },
  "homepage": "https://github.com/ryanlyn/claude-warmer",
  "bugs": {
    "url": "https://github.com/ryanlyn/claude-warmer/issues"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
